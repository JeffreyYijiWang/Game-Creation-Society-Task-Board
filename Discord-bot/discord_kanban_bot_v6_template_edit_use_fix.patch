+class TaskEditModal(discord.ui.Modal, title="Edit Existing Task"):
+    """Edit the text-heavy parts of an existing task.
+
+    This modal defers immediately on submit because syncing forum posts can take
+    more than three seconds. That avoids "The application did not respond."
+    """
+
+    def __init__(self, bot: commands.Bot, task: dict) -> None:
+        super().__init__()
+        self.bot = bot
+        self.task = task
+        self.task_title.default = task.get("title", "")
+        self.description.default = task.get("description", "")
+        self.priority.default = task.get("priority", "Medium")
+        self.thumbnail_url.default = task.get("thumbnail_url", "")
+        self.tags_and_links.default = (
+            f"tags: {task.get('tags', '')}\n"
+            f"links: {task.get('resource_links', '')}"
+        ).strip()
+
+    task_title = discord.ui.TextInput(label="Task title", max_length=100)
+    description = discord.ui.TextInput(label="Description", style=discord.TextStyle.paragraph, required=False, max_length=1000)
+    priority = discord.ui.TextInput(label="Priority", placeholder="Low, Medium, High, or Urgent", max_length=20)
+    thumbnail_url = discord.ui.TextInput(label="Thumbnail image URL", required=False, max_length=500)
+    tags_and_links = discord.ui.TextInput(
+        label="Tags and resource links",
+        placeholder="tags: Bug Fix, Code\nlinks: https://example.com/spec",
+        style=discord.TextStyle.paragraph,
+        required=False,
+        max_length=1000,
+    )
+
+    async def on_submit(self, interaction: discord.Interaction) -> None:
+        from taskbot.db import update_task
+        from taskbot.forum import sync_discord_task
+
+        tags, links = TaskCreateModal.parse_tags_and_links(str(self.tags_and_links.value))
+        await interaction.response.defer(ephemeral=True)
+        updated = update_task(
+            self.task["id"],
+            interaction.user.id,
+            "task_edited",
+            title=str(self.task_title.value).strip(),
+            description=str(self.description.value).strip(),
+            priority=str(self.priority.value).strip(),
+            thumbnail_url=str(self.thumbnail_url.value).strip(),
+            tags=tags,
+            resource_links=links,
+        )
+        if updated:
+            await sync_discord_task(self.bot, updated)
+            await interaction.followup.send(f"Updated task #{updated['id']}.", ephemeral=True)
+        else:
+            await interaction.followup.send("Task could not be updated.", ephemeral=True)
