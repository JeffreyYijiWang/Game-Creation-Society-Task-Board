+class TemplateListView(discord.ui.View):
+    def __init__(self, templates: list[dict], owner_id: int, *, timeout: float | None = 300) -> None:
+        super().__init__(timeout=timeout)
+        self.templates = templates[:25]
+        self.owner_id = owner_id
+        if self.templates:
+            self.add_item(TemplateSelect(self.templates, owner_id))
+
+
+class TemplateSelect(discord.ui.Select):
+    def __init__(self, templates: list[dict], owner_id: int) -> None:
+        self.templates_by_name = {t["name"]: t for t in templates}
+        self.owner_id = owner_id
+        options = [
+            discord.SelectOption(
+                label=t["name"][:100],
+                description=(t.get("title") or "Untitled task")[:100],
+                value=t["name"],
+            )
+            for t in templates[:25]
+        ]
+        super().__init__(placeholder="Pick a template to view/edit/use", min_values=1, max_values=1, options=options)
+
+    async def callback(self, interaction: discord.Interaction) -> None:
+        if interaction.user.id != self.owner_id:
+            await interaction.response.send_message("Only the template owner can open this list.", ephemeral=True)
+            return
+        from taskbot.embeds import template_detail_embed
+
+        name = self.values[0]
+        template = self.templates_by_name[name]
+        await interaction.response.edit_message(
+            embed=template_detail_embed(template),
+            view=TemplateDetailView(name, self.owner_id),
+        )
