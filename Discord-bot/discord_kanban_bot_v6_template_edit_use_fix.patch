+class TemplateDetailView(discord.ui.View):
+    """Buttons shown under a single template card.
+
+    Important: button callbacks that open a modal must call send_modal as the
+    first response. Do not call defer() before send_modal(), or Discord will show
+    "The application did not respond."
+    """
+
+    def __init__(self, template_name: str, owner_id: int, *, timeout: float | None = 300) -> None:
+        super().__init__(timeout=timeout)
+        self.template_name = template_name
+        self.owner_id = owner_id
+
+    async def _get_template_or_error(self, interaction: discord.Interaction) -> Optional[dict]:
+        if not interaction.guild:
+            await interaction.response.send_message("Templates only work inside a server.", ephemeral=True)
+            return None
+        template = get_template(interaction.guild.id, self.owner_id, self.template_name)
+        if not template:
+            await interaction.response.send_message("Template not found anymore.", ephemeral=True)
+            return None
+        return template
+
+    @discord.ui.button(label="Use Template", style=discord.ButtonStyle.success)
+    async def use_template(self, interaction: discord.Interaction, button: discord.ui.Button) -> None:
+        if interaction.user.id != self.owner_id:
+            await interaction.response.send_message("Only the template owner can use this saved template.", ephemeral=True)
+            return
+        template = await self._get_template_or_error(interaction)
+        if not template:
+            return
+        from taskbot.modals import TaskCreateModal
+
+        await interaction.response.send_modal(
+            TaskCreateModal(
+                interaction.client,  # type: ignore[arg-type]
+                thumbnail_url=template.get("thumbnail_url", ""),
+                positions_needed=int(template.get("positions_needed") or 1),
+                job_role=template.get("job_role", "Programmer"),
+                dev_environment=template.get("dev_environment") or template.get("dev_environments") or "Windows",
+                game_engine=template.get("game_engine", "Unity"),
+                custom_game_engine=template.get("custom_game_engine", ""),
+                template=template,
+            )
+        )
+
+    @discord.ui.button(label="Publish Now", style=discord.ButtonStyle.primary)
+    async def publish_now(self, interaction: discord.Interaction, button: discord.ui.Button) -> None:
+        if interaction.user.id != self.owner_id:
+            await interaction.response.send_message("Only the template owner can publish this template.", ephemeral=True)
+            return
+        template = await self._get_template_or_error(interaction)
